{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aimtune.github.io/chativa/schemas/messages/conversation.schema.json",
  "title": "Conversation",
  "description": "A single conversation listed by IConnector.listConversations() (multi-conversation / agent-panel mode). Source: packages/core/src/domain/entities/Conversation.ts.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "title", "status"],
  "properties": {
    "id":            { "type": "string", "description": "Unique identifier." },
    "title":         { "type": "string", "description": "Display title (e.g. 'Support Request #1234')." },
    "contact":       { "type": "string", "description": "Contact name / customer name." },
    "avatar":        { "type": "string", "format": "uri", "description": "Optional avatar URL." },
    "lastMessage":   { "type": "string", "description": "Preview of the last message." },
    "lastMessageAt": { "type": "integer", "description": "Unix epoch ms of the last message." },
    "unreadCount":   { "type": "integer", "minimum": 0, "description": "Number of unread messages in this conversation." },
    "status":        { "type": "string", "enum": ["open", "pending", "resolved", "closed"] },
    "metadata":      { "type": "object", "description": "Arbitrary extra data from the connector.", "additionalProperties": true }
  }
}
